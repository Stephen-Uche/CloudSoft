{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FeatureFlags": {
    "UseMongoDb": true
  },
  "MongoDb": {
    "ConnectionString": "mongodb://{username}:{password}@{hostname}:{port}",
    "DatabaseName": "cloudsoft",
    "SubscribersCollectionName": "subscribers"
  }
}




